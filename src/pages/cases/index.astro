---
import BaseLayout from '@/layouts/BaseLayout.astro';
import GridLines from '@/components/GridLines.astro';
import CaseListItem from '@/components/CaseListItem.astro';
import { getCollection } from 'astro:content';

const allCases = await getCollection('cases', ({ data }) => !data.draft);
const cases = allCases.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="Cases — Giovany Jr"
  description="Trabalhos selecionados em product design: food-tech, design systems, B2B SaaS. Orientado por método, amplificado por IA."
>

  <section style="position: relative; overflow: hidden; padding: 5rem 2rem 5rem; max-width: 1200px; margin: 0 auto;">
    <GridLines />
    <div style="position: relative; z-index: 1;">
      <p data-reveal="hero" style="font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted-foreground); margin-bottom: 1.5rem;">CASES</p>
      <h1 data-reveal="hero" style="font-family: var(--font-mono); font-size: clamp(3rem, 8vw, 6rem); font-weight: 700; letter-spacing: -0.04em; line-height: 0.95; transition-delay: 120ms;">
        Trabalhos selecionados.
      </h1>
    </div>
  </section>

  <section style="max-width: 1200px; margin: 0 auto; padding: 0 2rem;">
    {cases.map((c, i) => (
      <CaseListItem
        number={String(i + 1).padStart(2, '0')}
        tag={c.data.tags[0] ?? 'PRODUTO'}
        title={c.data.title}
        subtitle={c.data.description}
        cover={c.data.cover}
        metric={c.data.metric}
        slug={c.slug}
        index={i}
      />
    ))}
    <div style="border-top: 1px solid var(--border);"></div>
  </section>

</BaseLayout>
