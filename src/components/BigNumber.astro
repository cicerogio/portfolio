---
interface Props {
  number: string;
  label: string;
  context: string;
}
const { number, label, context } = Astro.props;
---

<div data-reveal="scroll" class="bignum">
  <p class="bignum-number">{number}</p>
  <p class="bignum-label">{label}</p>
  <p class="bignum-context">{context}</p>
</div>

<style>
  .bignum {
    padding: var(--bng-padding, 2.5rem 0);
    border-top: 1px solid var(--border);
  }

  .bignum-number {
    font-family: var(--font-mono);
    font-size: var(--bng-num-size, clamp(2.25rem, 6vw, 3.75rem));
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--foreground);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .bignum-label {
    font-family: var(--font-mono);
    font-size: var(--bng-label-size, 0.7rem);
    font-weight: 700;
    color: var(--muted-foreground);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.75rem;
  }

  .bignum-context {
    font-family: var(--font-sans);
    font-size: var(--bng-context-size, 0.875rem);
    line-height: 1.7;
    color: var(--muted-foreground);
  }
</style>
