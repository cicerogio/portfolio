---
import { BASE } from '@/consts';

interface Props {
  number: string;
  tag: string;
  title: string;
  subtitle: string;
  cover: string;
  thumbnail?: string;
  coverVideo?: string;
  metric: string;
  slug: string;
  index: number;
  comingSoon?: boolean;
}

const { number, tag, title, subtitle, cover, thumbnail, coverVideo, metric, slug, index, comingSoon = false } = Astro.props;
const href = `${BASE}/cases/${slug}`;
const imgSrc = BASE + (thumbnail ?? cover);
const videoSrc = coverVideo ? BASE + coverVideo : undefined;
---

<article
  data-reveal="scroll"
  style={`transition-delay: ${index * 80}ms; border-top: 1px solid var(--border); padding: 3rem 0; ${comingSoon ? 'opacity: 0.6;' : ''}`}
>
  <!-- Top row: number + tag -->
  <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
    {comingSoon ? (
      <span style="font-family: var(--font-mono); font-size: 0.6rem; font-weight: 700; letter-spacing: 0.14em; color: var(--muted-foreground); text-transform: uppercase; border: 1px solid var(--border); padding: 0.2em 0.6em;">
        EM BREVE
      </span>
    ) : (
      <span style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--accent); font-weight: 700; letter-spacing: 0.1em;">
        {number}
      </span>
    )}
    <span style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--muted-foreground); letter-spacing: 0.1em; text-transform: uppercase;">
      {tag}
    </span>
  </div>

  <!-- Title -->
  <h3 style="font-family: var(--font-mono); font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 700; line-height: 1.1; letter-spacing: -0.02em; color: var(--foreground); margin-bottom: 0.75rem;">
    {title}
  </h3>

  <!-- Subtitle -->
  <p style="font-family: var(--font-mono); font-size: 0.85rem; color: var(--muted-foreground); margin-bottom: 2rem; line-height: 1.6;">
    {subtitle}
  </p>

  <!-- Case image -->
  {comingSoon ? (
    <div style="display: block; margin-bottom: 1.5rem; overflow: hidden; position: relative;">
      <div class="img-placeholder" style="width: 100%; aspect-ratio: 16/9;">
        <img
          src={imgSrc}
          alt={`${title} screenshot`}
          style="width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0; z-index: 2;"
          onerror="this.style.display='none';"
          loading="lazy"
        />
        <span>{title} — screenshot placeholder</span>
      </div>
    </div>
  ) : (
    <a href={href} style="display: block; margin-bottom: 1.5rem; overflow: hidden; position: relative;" aria-label={`Open case: ${title}`}>
      <div class="img-placeholder case-img-hover" style="width: 100%; aspect-ratio: 16/9;">
        {videoSrc ? (
          <video
            autoplay
            loop
            muted
            playsinline
            preload="metadata"
            poster={imgSrc}
            aria-label={`${title} — preview`}
            style="width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0; z-index: 2; transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);"
          >
            <source src={videoSrc} type="video/mp4" />
            <img src={imgSrc} alt={`${title} screenshot`} style="width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0; z-index: 2;" />
          </video>
        ) : (
          <img
            src={imgSrc}
            alt={`${title} screenshot`}
            style="width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0; z-index: 2; transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), filter 0.3s ease;"
            onerror="this.style.display='none';"
            loading="lazy"
          />
        )}
        <span>{title} — screenshot placeholder</span>
      </div>
    </a>
  )}

  <!-- Bottom row: metric + link -->
  <div style="display: flex; align-items: baseline; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
    <p style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--muted-foreground); letter-spacing: 0.04em;">
      <span style={`color: ${comingSoon ? 'var(--muted-foreground)' : 'var(--accent)'}; font-weight: 700;`}>{comingSoon ? '—' : '↗'}</span> {metric}
    </p>
    {!comingSoon && (
      <a
        href={href}
        class="underline-hover"
        style="font-family: var(--font-mono); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em; color: var(--foreground); text-decoration: none; text-transform: uppercase;"
      >
        Ver case →
      </a>
    )}
  </div>
</article>

<style>
  .case-img-hover img:hover {
    transform: scale(1.02);
    filter: brightness(0.95);
  }
</style>
