---
interface Props {
  label?: string;
}
const { label = 'Nota técnica' } = Astro.props;
---

<aside class="tech-note">
  <p class="tech-note-label">{label}</p>
  <div class="tech-note-body">
    <slot />
  </div>
</aside>

<style>
  .tech-note {
    background: var(--muted);
    border-left: 2px solid var(--accent);
    padding: 1rem 1.25rem;
    margin: 2rem 0;
    border-radius: 0 3px 3px 0;
  }

  .tech-note-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .tech-note-body {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.75;
    color: var(--muted-foreground);
  }

  .tech-note-body :global(p) {
    margin: 0;
    font-size: 0.875rem;
    color: var(--muted-foreground);
  }
</style>
