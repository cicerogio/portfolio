---
import { AUTHOR, SOCIAL } from '@/consts';

const year = new Date().getFullYear();
---

<footer style="border-top: 1px solid var(--border); margin-top: 8rem;">
  <div style="max-width: 1200px; margin: 0 auto; padding: 2.5rem 2rem; display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 2rem;">

    <!-- Left: photo + info -->
    <div style="display: flex; align-items: center; gap: 1rem;">
      <img
        src="/portfolio/avatar.jpg"
        alt="Cicero Giovany Junior, Lead Product Designer"
        width="48"
        height="48"
        style="width: 48px; height: 48px; border-radius: 50%; object-fit: cover; object-position: center; border: 1px solid var(--border); flex-shrink: 0;"
      />
      <div>
        <p style="font-family: var(--font-mono); font-size: 0.75rem; font-weight: 700; color: var(--foreground); line-height: 1.3;">{AUTHOR.short}</p>
        <p style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--muted-foreground); letter-spacing: 0.04em; line-height: 1.3;">{AUTHOR.role} · {AUTHOR.location}</p>
      </div>
    </div>

    <!-- Center: social links -->
    <nav aria-label="Social links" style="display: flex; align-items: center; gap: 1.5rem;">
      {[
        { href: SOCIAL.email, label: 'EMAIL' },
        { href: SOCIAL.linkedin, label: 'LINKEDIN', external: true },
        { href: SOCIAL.github, label: 'GITHUB', external: true },
      ].map(({ href, label, external }) => (
        <a
          href={href}
          target={external ? '_blank' : undefined}
          rel={external ? 'noopener noreferrer' : undefined}
          class="underline-hover"
          style="font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.1em; font-weight: 500; color: var(--muted-foreground); text-decoration: none; transition: color 0.2s;"
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- Right: copyright -->
    <p style="font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.06em; color: var(--muted-foreground);">
      &copy; {year}
    </p>
  </div>
</footer>
