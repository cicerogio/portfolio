---
---
<div style="display: flex; align-items: center; gap: 0.25rem; font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.08em;">
  <span style="color: var(--foreground); font-weight: 700;">PT</span>
  <span style="color: var(--border);">/</span>
  <div style="position: relative; display: inline-block;">
    <button
      disabled
      aria-disabled="true"
      style="background: none; border: none; cursor: not-allowed; color: var(--muted-foreground); font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.08em; opacity: 0.4; padding: 0;"
      class="lang-en-btn"
    >
      EN
    </button>
    <span
      class="lang-tooltip"
      role="tooltip"
      style="position: absolute; bottom: -2rem; left: 50%; transform: translateX(-50%); white-space: nowrap; font-size: 0.65rem; background: var(--foreground); color: var(--background); padding: 0.2rem 0.4rem; pointer-events: none; opacity: 0; transition: opacity 0.15s; z-index: 50;"
    >
      soon
    </span>
  </div>
</div>

<style>
  .lang-en-btn:hover + .lang-tooltip,
  .lang-en-btn:focus + .lang-tooltip {
    opacity: 1 !important;
  }
</style>
