---
import BaseLayout from '@/layouts/BaseLayout.astro';
import GridLines from '@/components/GridLines.astro';
import CaseListItem from '@/components/CaseListItem.astro';
import { getCollection } from 'astro:content';
import { AUTHOR, CREDENTIALS, BASE } from '@/consts';

const allCases = await getCollection('cases', ({ data }) => !data.draft);
const cases = allCases.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout>

  <!-- ── HERO ──────────────────────────────────────────── -->
  <section style="position: relative; overflow: hidden; padding: 6rem 2rem 8rem; max-width: 1200px; margin: 0 auto;">
    <GridLines />
    <div style="position: relative; z-index: 1; max-width: 900px;">

      <p
        data-reveal="hero"
        style="font-family: var(--font-mono); font-size: 0.7rem; font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted-foreground); margin-bottom: 2rem;"
      >
        LEAD PRODUCT DESIGNER · 09 ANOS
      </p>

      <h1 style="font-family: var(--font-mono); font-weight: 700; letter-spacing: -0.04em; line-height: 0.95; margin-bottom: 2.5rem; overflow: hidden;">
        <span data-reveal="hero" style="display: block; font-size: clamp(4rem, 10vw, 9rem); transition-delay: 120ms;">Criando produtos</span>
        <span data-reveal="hero" style="display: block; font-size: clamp(4rem, 10vw, 9rem); transition-delay: 240ms;">com método</span>
        <span data-reveal="hero" style="display: block; font-size: clamp(4rem, 10vw, 9rem); color: var(--accent); transition-delay: 360ms;">e IA.</span>
      </h1>

      <p
        data-reveal="hero"
        style="font-family: var(--font-mono); font-size: 1rem; color: var(--muted-foreground); max-width: 52ch; line-height: 1.7; margin-bottom: 2.5rem; transition-delay: 480ms;"
      >
        Atualmente no food-tech no Brasil.<br />
        Aberto a posições sênior/lead em product design, preferencialmente remote-first.
      </p>

      <div data-reveal="hero" style="display: flex; gap: 2rem; align-items: center; flex-wrap: wrap; transition-delay: 560ms;">
        <a
          href={`${BASE}/cases`}
          class="underline-hover"
          style="font-family: var(--font-mono); font-size: 0.85rem; font-weight: 700; letter-spacing: 0.08em; color: var(--foreground); text-decoration: none; text-transform: uppercase;"
        >
          Ver trabalhos →
        </a>
        <a
          href={`${BASE}/contato`}
          class="underline-hover"
          style="font-family: var(--font-mono); font-size: 0.85rem; font-weight: 500; letter-spacing: 0.08em; color: var(--muted-foreground); text-decoration: none; text-transform: uppercase;"
        >
          Entrar em contato →
        </a>
      </div>
    </div>
  </section>

  <!-- ── CREDENTIALS STRIP ─────────────────────────────── -->
  <div style="border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); overflow: hidden; padding: 0.875rem 0;">
    <div style="display: flex; align-items: center; gap: 2rem; white-space: nowrap;">
      <span style="font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.12em; color: var(--muted-foreground); text-transform: uppercase; padding: 0 2rem; flex-shrink: 0;">
        Anteriormente em
      </span>
      <div class="marquee-track" style="gap: 3rem; display: flex; align-items: center;">
        {[...CREDENTIALS, ...CREDENTIALS].map((name) => (
          <span style="font-family: var(--font-mono); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.14em; color: var(--muted-foreground); text-transform: uppercase; flex-shrink: 0;">
            {name}
          </span>
        ))}
      </div>
    </div>
  </div>

  <!-- ── TRABALHOS SELECIONADOS ─────────────────────────── -->
  <section style="max-width: 1200px; margin: 0 auto; padding: 6rem 2rem 0;">
    <div data-reveal="scroll" style="display: flex; align-items: baseline; gap: 1rem; margin-bottom: 0;">
      <span style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--accent); font-weight: 700; letter-spacing: 0.1em;">01</span>
      <h2 style="font-family: var(--font-mono); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted-foreground);">
        TRABALHOS SELECIONADOS
      </h2>
    </div>

    {cases.map((c, i) => (
      <CaseListItem
        number={String(i + 1).padStart(2, '0')}
        tag={c.data.tags[0] ?? 'PRODUTO'}
        title={c.data.title}
        subtitle={c.data.description}
        cover={c.data.cover}
        metric={c.data.metric}
        slug={c.slug}
        index={i}
      />
    ))}
    <div style="border-top: 1px solid var(--border);"></div>
  </section>

  <!-- ── SOBRE (resumo) ─────────────────────────────────── -->
  <section style="max-width: 1200px; margin: 0 auto; padding: 6rem 2rem;">
    <div data-reveal="scroll" style="display: flex; align-items: baseline; gap: 1rem; margin-bottom: 3rem;">
      <span style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--accent); font-weight: 700; letter-spacing: 0.1em;">02</span>
      <h2 style="font-family: var(--font-mono); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted-foreground);">
        SOBRE
      </h2>
    </div>

    <div style="max-width: 640px;">
      {AUTHOR.bio.map((para, i) => (
        <p
          data-reveal="scroll"
          style={`font-family: var(--font-mono); font-size: 1rem; line-height: 1.8; color: var(--muted-foreground); margin-bottom: 1.25rem; transition-delay: ${i * 80}ms;`}
        >
          {para}
        </p>
      ))}

      <a
        data-reveal="scroll"
        href={`${BASE}/sobre`}
        class="underline-hover"
        style="display: inline-block; font-family: var(--font-mono); font-size: 0.8rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--foreground); text-decoration: none; margin-top: 0.5rem; transition-delay: 160ms;"
      >
        Ler mais →
      </a>
    </div>
  </section>

</BaseLayout>
