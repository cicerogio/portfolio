<div id="cursor-dot" transition:persist aria-hidden="true"></div>

<script>
  // Runs once. transition:persist keeps the element alive across navigations.
  const cursor = document.getElementById('cursor-dot');
  if (cursor && !window.matchMedia('(pointer: coarse)').matches) {
    const c = cursor; // narrowed to HTMLElement for use inside closures
    let rafId: number | null = null;
    let tx = -100, ty = -100;

    document.addEventListener('mousemove', (e) => {
      tx = e.clientX;
      ty = e.clientY;
      if (!rafId) rafId = requestAnimationFrame(() => {
        c.style.transform = `translate(${tx - 6}px, ${ty - 6}px)`;
        rafId = null;
      });
    });

    document.addEventListener('mouseleave', () => { c.style.opacity = '0'; });
    document.addEventListener('mouseenter', () => { c.style.opacity = '1'; });

    // Re-attach expand listeners after every page transition (new links appear)
    function attachExpand() {
      document.querySelectorAll('a, button, [data-cursor-expand]').forEach((el) => {
        el.addEventListener('mouseenter', () => c.classList.add('expanded'));
        el.addEventListener('mouseleave', () => c.classList.remove('expanded'));
      });
    }

    document.addEventListener('astro:page-load', attachExpand);
    attachExpand();
  } else if (cursor) {
    cursor.style.display = 'none';
  }
</script>
