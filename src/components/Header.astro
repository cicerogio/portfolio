---
import LanguageToggle from './LanguageToggle.astro';
import ThemeToggle from './ThemeToggle.astro';
import { NAV_LINKS, AUTHOR, BASE } from '@/consts';

const currentPath = Astro.url.pathname;
---

<header id="site-header" style="
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1px solid var(--border);
  background: color-mix(in srgb, var(--background) 80%, transparent);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
">
  <div style="max-width: 1200px; margin: 0 auto; padding: 0 2rem; height: 56px; display: flex; align-items: center; justify-content: space-between; gap: 2rem;">

    <!-- Logo -->
    <a
      href={`${BASE}/`}
      style="display: flex; align-items: center; flex-shrink: 0; transition: opacity 0.2s; color: var(--foreground);"
      class="logo-link"
      aria-label={`${AUTHOR.short} — home`}
    >
      <svg width="28" height="28" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path fill-rule="evenodd" clip-rule="evenodd" d="M39.8008 17.1667C38.4248 7.46283 30.0839 0 20 0C8.95434 0 0 8.95432 0 20C0 31.0456 8.95434 40 20 40V31.2316C13.7931 31.2091 8.76825 26.1705 8.76825 19.9582C8.76825 13.7321 13.8156 8.68474 20.0418 8.68474C25.3044 8.68474 29.7248 12.2907 30.9669 17.1667H39.8008Z" fill="currentColor"/>
        <path d="M30 31.25H20L20 40L30 40V31.25Z" fill="#7964FF"/>
        <path d="M30 22.5H20V31.25H30V22.5Z" fill="#0B00C8"/>
        <path d="M40 22.5H30V31.25L40 31.25V22.5Z" fill="#0B00C8"/>
        <path d="M40 31.25L30 31.25V40H40V31.25Z" fill="#0B00C8"/>
      </svg>
    </a>

    <!-- Nav desktop -->
    <nav aria-label="Main navigation" style="display: flex; align-items: center; gap: 0.25rem;">
      {NAV_LINKS.map(({ href, label }) => {
        const isActive = currentPath.startsWith(href);
        return (
          <a
            href={href}
            style={`
              font-family: var(--font-mono);
              font-size: 0.7rem;
              font-weight: 500;
              letter-spacing: 0.1em;
              padding: 0.375rem 0.75rem;
              text-decoration: none;
              transition: color 0.2s;
              color: ${isActive ? 'var(--foreground)' : 'var(--muted-foreground)'};
              ${isActive ? 'font-weight: 700;' : ''}
            `}
            aria-current={isActive ? 'page' : undefined}
          >
            {label}
          </a>
        );
      })}
    </nav>

    <!-- Right controls -->
    <div style="display: flex; align-items: center; gap: 1.25rem; flex-shrink: 0;">
      <LanguageToggle />
      <ThemeToggle />

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        aria-label="Toggle menu"
        aria-expanded="false"
        style="
          display: none;
          background: none;
          border: none;
          cursor: none;
          color: var(--muted-foreground);
          font-family: var(--font-mono);
          font-size: 0.7rem;
          letter-spacing: 0.1em;
        "
      >
        MENU
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <div
    id="mobile-nav"
    style="
      display: none;
      border-top: 1px solid var(--border);
      background: var(--background);
      padding: 1rem 2rem;
      flex-direction: column;
      gap: 0;
    "
  >
    {NAV_LINKS.map(({ href, label }) => (
      <a
        href={href}
        style="
          font-family: var(--font-mono);
          font-size: 0.75rem;
          letter-spacing: 0.1em;
          font-weight: 500;
          color: var(--muted-foreground);
          text-decoration: none;
          padding: 0.875rem 0;
          border-bottom: 1px solid var(--border);
        "
      >
        {label}
      </a>
    ))}
  </div>
</header>

<style>
  @media (max-width: 640px) {
    #mobile-menu-btn { display: block !important; }
    nav { display: none !important; }
  }

  .logo-link:hover { opacity: 0.6; }
</style>

<script is:inline>
  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const nav = document.getElementById('mobile-nav');
    if (!btn || !nav) return;
    btn.addEventListener('click', () => {
      const open = nav.style.display === 'flex';
      nav.style.display = open ? 'none' : 'flex';
      btn.setAttribute('aria-expanded', String(!open));
      btn.textContent = open ? 'MENU' : 'CLOSE';
    });
  }
  document.addEventListener('astro:page-load', initMobileMenu);
</script>
