---
interface Props {
  caption: string;
  aspectRatio?: string;
}
const { caption, aspectRatio = '16/9' } = Astro.props;
---

<figure style="margin: 2.5rem 0;">
  <div
    class="img-placeholder"
    style={`width: 100%; aspect-ratio: ${aspectRatio};`}
  >
    <span>Mockup em produção</span>
  </div>
  <figcaption style="font-family: var(--font-mono); font-size: 0.6rem; color: var(--muted-foreground); letter-spacing: 0.08em; text-transform: uppercase; margin-top: 0.625rem; text-align: center;">
    {caption}
  </figcaption>
</figure>
